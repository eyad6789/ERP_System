# Copy to .env and fill in. NEVER commit a real .env.

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-prod-use-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:5173

# --- Database (app connects as a NON-superuser, NON-BYPASSRLS role) ---
POSTGRES_DB=erp
POSTGRES_USER=erp_app
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis (cache / sessions / celery) ---
REDIS_URL=redis://redis:6379/0

# --- Frontend ---
VITE_API_BASE=/api
